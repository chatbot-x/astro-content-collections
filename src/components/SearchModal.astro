---
/**
 * SearchModal — Pagefind Component UI integration.
 * Loads Pagefind CSS + JS and provides a modal search dialog.
 * Triggered by search buttons in the Navbar (both desktop and mobile).
 * Includes prominent Cancel/Close button for mobile devices.
 */
---

<div id="search-modal" class="hidden">
  <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-component-ui.js" type="module"></script>

  <!-- Backdrop -->
  <div
    id="search-backdrop"
    class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm transition-opacity"
  ></div>

  <!-- Modal container -->
  <div class="fixed inset-0 z-50 flex items-start justify-center pt-[10vh] px-4 sm:pt-[10vh]">
    <div class="w-full max-w-2xl rounded-xl bg-white dark:bg-gray-900 shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <!-- Search header with close button -->
      <div class="flex items-center justify-between border-b border-gray-200 dark:border-gray-700 px-4 py-2">
        <span class="text-sm text-gray-500 dark:text-gray-400">Search</span>
        <button
          id="search-close-btn"
          type="button"
          aria-label="Close search"
          class="inline-flex items-center justify-center rounded-lg p-1.5 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <pagefind-searchbox id="search-searchbox"></pagefind-searchbox>
      <pagefind-results id="search-results" class="max-h-[60vh] overflow-y-auto"></pagefind-results>
      <!-- Mobile cancel button — large, touch-friendly -->
      <div class="border-t border-gray-200 dark:border-gray-700 p-3 sm:hidden">
        <button
          id="search-cancel-btn"
          type="button"
          class="w-full rounded-lg bg-indigo-600 px-4 py-3 text-base font-semibold text-white hover:bg-indigo-700 active:bg-indigo-800 transition-colors shadow-sm"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initSearchModal() {
    const searchModal = document.getElementById('search-modal');
    const searchBackdrop = document.getElementById('search-backdrop');
    const searchCloseBtn = document.getElementById('search-close-btn');
    const searchCancelBtn = document.getElementById('search-cancel-btn');

    // Support both desktop and mobile search buttons
    const searchBtnDesktop = document.getElementById('search-btn');
    const searchBtnMobile = document.getElementById('search-btn-mobile');

    if (!searchModal || !searchBackdrop) return;

    function openSearch() {
      searchModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Focus the Pagefind input after a small delay for web component to render
      setTimeout(() => {
        const input = searchModal.querySelector('input');
        if (input) input.focus();
      }, 150);
    }

    function closeSearch() {
      searchModal.classList.add('hidden');
      document.body.style.overflow = '';
      // Clear search input on close
      const input = searchModal.querySelector('input');
      if (input) input.value = '';
      // Reset Pagefind results
      const results = searchModal.querySelector('pagefind-results');
      if (results) results.innerHTML = '';
    }

    // Desktop search button
    if (searchBtnDesktop) {
      searchBtnDesktop.addEventListener('click', openSearch);
    }

    // Mobile search button — direct trigger (no forwarding to hidden button)
    if (searchBtnMobile) {
      searchBtnMobile.addEventListener('click', openSearch);
    }

    // Backdrop click to close
    searchBackdrop.addEventListener('click', closeSearch);

    // Close button (X) — visible on all screen sizes
    if (searchCloseBtn) {
      searchCloseBtn.addEventListener('click', closeSearch);
    }

    // Cancel button — mobile only, prominent
    if (searchCancelBtn) {
      searchCancelBtn.addEventListener('click', closeSearch);
    }

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // Cmd/Ctrl + K to open/toggle
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (searchModal.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
      // Escape to close
      if (e.key === 'Escape' && !searchModal.classList.contains('hidden')) {
        closeSearch();
      }
    });
  }

  initSearchModal();
  document.addEventListener('astro:after-swap', initSearchModal);
  document.addEventListener('astro:page-load', initSearchModal);
</script>
