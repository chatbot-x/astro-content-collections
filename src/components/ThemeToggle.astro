---
/**
 * ThemeToggle — 3-mode (Light / Dark / System) toggle component.
 * Uses the __ASTRO_THEMES__ API exposed by ThemeProvider.
 * Props: mode="desktop" | "mobile" to generate unique IDs.
 *
 * FIX (AUD-010): Added full keyboard navigation per WAI-ARIA Authoring Practices:
 * - Arrow Up/Down moves focus between menu items
 * - Enter/Space activates the focused item
 * - Escape closes the menu
 * - Home/End move to first/last item
 */
interface Props {
  mode?: 'desktop' | 'mobile';
}

const { mode = 'desktop' } = Astro.props;
const suffix = mode === 'mobile' ? '-mobile' : '';
---

<div class="relative flex items-center">
  <!-- Simple toggle button (light ↔ dark) -->
  <button
    id={`theme-toggle${suffix}`}
    type="button"
    aria-label="Toggle dark mode"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls={`theme-menu${suffix}`}
    class="relative inline-flex h-9 w-9 items-center justify-center rounded-lg text-indigo-100 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50"
  >
    <!-- Sun icon (shown in dark mode) -->
    <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <!-- Moon icon (shown in light mode) -->
    <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>

  <!-- 3-mode dropdown (appears on click) -->
  <div id={`theme-menu${suffix}`} role="menu" aria-label="Theme options" class="hidden absolute right-0 top-full mt-2 w-36 rounded-lg bg-white dark:bg-gray-800 shadow-lg ring-1 ring-black/5 dark:ring-white/10 py-1 z-50">
    <button data-theme-choice="light" role="menuitem" tabindex="-1" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 focus:bg-gray-100 dark:focus:bg-gray-700 focus:outline-none transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      Light
    </button>
    <button data-theme-choice="dark" role="menuitem" tabindex="-1" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 focus:bg-gray-100 dark:focus:bg-gray-700 focus:outline-none transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      Dark
    </button>
    <button data-theme-choice="system" role="menuitem" tabindex="-1" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 focus:bg-gray-100 dark:focus:bg-gray-700 focus:outline-none transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      System
    </button>
  </div>
</div>

<script>
  function initThemeToggle(suffix = '') {
    const toggleBtn = document.getElementById(`theme-toggle${suffix}`);
    const menu = document.getElementById(`theme-menu${suffix}`);
    const choices = menu?.querySelectorAll<HTMLButtonElement>('[data-theme-choice]');

    if (!toggleBtn || !menu || !choices) return;

    const controller = new AbortController();

    // FIX (AUD-010): WAI-ARIA keyboard navigation for menu pattern.
    // Uses roving tabindex: only the active item has tabindex="0",
    // all others have tabindex="-1". Arrow keys move the active item.
    let currentIndex = -1;

    function openMenu() {
      menu.classList.remove('hidden');
      toggleBtn.setAttribute('aria-expanded', 'true');
      // Focus the first item by default
      currentIndex = 0;
      focusItem(currentIndex);
    }

    function closeMenu() {
      menu.classList.add('hidden');
      toggleBtn.setAttribute('aria-expanded', 'false');
      // Reset tabindex on all items
      choices.forEach((c) => c.setAttribute('tabindex', '-1'));
      currentIndex = -1;
    }

    function isOpen() {
      return !menu.classList.contains('hidden');
    }

    function focusItem(index: number) {
      if (index < 0 || index >= choices.length) return;
      choices.forEach((c) => c.setAttribute('tabindex', '-1'));
      choices[index].setAttribute('tabindex', '0');
      choices[index].focus();
      currentIndex = index;
    }

    function activateItem(index: number) {
      if (index < 0 || index >= choices.length) return;
      const theme = choices[index].dataset.themeChoice as 'light' | 'dark' | 'system';
      if (window.__ASTRO_THEMES__) {
        window.__ASTRO_THEMES__.setTheme(theme);
      }
      closeMenu();
      toggleBtn.focus();
    }

    // Toggle dropdown on button click
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen()) {
        closeMenu();
      } else {
        openMenu();
      }
    }, { signal: controller.signal });

    // Close dropdown when clicking outside
    document.addEventListener('click', () => {
      closeMenu();
    }, { signal: controller.signal });

    // Prevent menu from closing when clicking inside it
    menu.addEventListener('click', (e) => {
      e.stopPropagation();
    }, { signal: controller.signal });

    // Set theme on choice click
    choices.forEach((choice, i) => {
      choice.addEventListener('click', () => {
        activateItem(i);
      }, { signal: controller.signal });
    });

    // FIX (AUD-010): Keyboard navigation per WAI-ARIA Authoring Practices
    toggleBtn.addEventListener('keydown', (e: KeyboardEvent) => {
      switch (e.key) {
        case 'ArrowDown':
        case 'Down':
          e.preventDefault();
          if (!isOpen()) {
            openMenu();
          } else {
            focusItem((currentIndex + 1) % choices.length);
          }
          break;
        case 'ArrowUp':
        case 'Up':
          e.preventDefault();
          if (!isOpen()) {
            openMenu();
            focusItem(choices.length - 1); // Open at last item
          } else {
            focusItem((currentIndex - 1 + choices.length) % choices.length);
          }
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (isOpen() && currentIndex >= 0) {
            activateItem(currentIndex);
          } else {
            openMenu();
          }
          break;
        case 'Escape':
          if (isOpen()) {
            e.preventDefault();
            closeMenu();
            toggleBtn.focus();
          }
          break;
        case 'Home':
          if (isOpen()) {
            e.preventDefault();
            focusItem(0);
          }
          break;
        case 'End':
          if (isOpen()) {
            e.preventDefault();
            focusItem(choices.length - 1);
          }
          break;
      }
    }, { signal: controller.signal });

    // Keyboard navigation within menu items
    menu.addEventListener('keydown', (e: KeyboardEvent) => {
      switch (e.key) {
        case 'ArrowDown':
        case 'Down':
          e.preventDefault();
          focusItem((currentIndex + 1) % choices.length);
          break;
        case 'ArrowUp':
        case 'Up':
          e.preventDefault();
          focusItem((currentIndex - 1 + choices.length) % choices.length);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (currentIndex >= 0) {
            activateItem(currentIndex);
          }
          break;
        case 'Escape':
          e.preventDefault();
          closeMenu();
          toggleBtn.focus();
          break;
        case 'Home':
          e.preventDefault();
          focusItem(0);
          break;
        case 'End':
          e.preventDefault();
          focusItem(choices.length - 1);
          break;
        case 'Tab':
          // Tab moves focus out of the menu — close it
          closeMenu();
          break;
      }
    }, { signal: controller.signal });

    // Return cleanup function for View Transitions
    return () => controller.abort();
  }

  // Store cleanup functions to prevent listener leaks on View Transitions
  let cleanupDesktop: (() => void) | undefined;
  let cleanupMobile: (() => void) | undefined;

  function reInitThemeToggles() {
    cleanupDesktop?.();
    cleanupMobile?.();
    cleanupDesktop = initThemeToggle('');
    cleanupMobile = initThemeToggle('-mobile');
  }

  // astro:page-load fires on both initial load AND after View Transitions swaps
  document.addEventListener('astro:page-load', reInitThemeToggles);
</script>
