---
/**
 * ThemeToggle — 3-mode (Light / Dark / System) toggle component.
 * Uses the __ASTRO_THEMES__ API exposed by ThemeProvider.
 * Props: mode="desktop" | "mobile" to generate unique IDs.
 */
interface Props {
  mode?: 'desktop' | 'mobile';
}

const { mode = 'desktop' } = Astro.props;
const suffix = mode === 'mobile' ? '-mobile' : '';
---

<div class="relative flex items-center">
  <!-- Simple toggle button (light ↔ dark) -->
  <button
    id={`theme-toggle${suffix}`}
    type="button"
    aria-label="Toggle dark mode"
    aria-haspopup="menu"
    aria-expanded="false"
    class="relative inline-flex h-9 w-9 items-center justify-center rounded-lg text-indigo-100 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50"
  >
    <!-- Sun icon (shown in dark mode) -->
    <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <!-- Moon icon (shown in light mode) -->
    <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>

  <!-- 3-mode dropdown (appears on click) -->
  <div id={`theme-menu${suffix}`} role="menu" class="hidden absolute right-0 top-full mt-2 w-36 rounded-lg bg-white dark:bg-gray-800 shadow-lg ring-1 ring-black/5 dark:ring-white/10 py-1 z-50">
    <button data-theme-choice="light" role="menuitem" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      Light
    </button>
    <button data-theme-choice="dark" role="menuitem" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      Dark
    </button>
    <button data-theme-choice="system" role="menuitem" class="flex w-full items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      System
    </button>
  </div>
</div>

<script>
  function initThemeToggle(suffix = '') {
    const toggleBtn = document.getElementById(`theme-toggle${suffix}`);
    const menu = document.getElementById(`theme-menu${suffix}`);
    const choices = menu?.querySelectorAll('[data-theme-choice]');

    if (!toggleBtn || !menu || !choices) return;

    const controller = new AbortController();

    // Toggle dropdown on button click
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    }, { signal: controller.signal });

    // Close dropdown when clicking outside
    document.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggleBtn.setAttribute('aria-expanded', 'false');
    }, { signal: controller.signal });

    // Prevent menu from closing when clicking inside it
    menu.addEventListener('click', (e) => {
      e.stopPropagation();
    }, { signal: controller.signal });

    // Set theme on choice click
    choices.forEach((choice) => {
      choice.addEventListener('click', () => {
        const theme = (choice as HTMLElement).dataset.themeChoice as 'light' | 'dark' | 'system';
        if (window.__ASTRO_THEMES__) {
          window.__ASTRO_THEMES__.setTheme(theme);
        }
        menu.classList.add('hidden');
        toggleBtn.setAttribute('aria-expanded', 'false');
      }, { signal: controller.signal });
    });

    // Return cleanup function for View Transitions
    return () => controller.abort();
  }

  // Store cleanup functions to prevent listener leaks on View Transitions
  let cleanupDesktop: (() => void) | undefined;
  let cleanupMobile: (() => void) | undefined;

  function reInitThemeToggles() {
    cleanupDesktop?.();
    cleanupMobile?.();
    cleanupDesktop = initThemeToggle('');
    cleanupMobile = initThemeToggle('-mobile');
  }

  // astro:page-load fires on both initial load AND after View Transitions swaps
  document.addEventListener('astro:page-load', reInitThemeToggles);
</script>
