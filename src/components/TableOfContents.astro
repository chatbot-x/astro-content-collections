---
/**
 * TableOfContents — auto-generated from Astro's `headings` prop.
 *
 * Renders an accessible <nav> with h2/h3 headings as nested links.
 * All styling via Tailwind — no scoped CSS.
 * Works both inline (mobile) and inside a sticky sidebar (desktop).
 */
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  minHeadings?: number;
}

const { headings, minHeadings = 2 } = Astro.props;

// Only show h2 and h3 headings (skip h1 which is the page title)
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// Don't render TOC if there aren't enough headings to justify it
if (tocHeadings.length < minHeadings) return;
---

<nav
  aria-label="Table of Contents"
  class="rounded-xl border border-gray-200 bg-gradient-to-br from-slate-50 to-slate-100 p-5 dark:border-gray-700 dark:from-gray-800 dark:to-gray-900"
>
  <div class="flex items-center gap-2 mb-3">
    <svg class="h-4 w-4 text-indigo-500 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10M4 18h7" />
    </svg>
    <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">On this page</span>
  </div>
  <ul class="flex flex-col gap-0.5 list-none p-0 m-0">
    {tocHeadings.map((heading) => (
      <li class="leading-normal">
        <a
          href={`#${heading.slug}`}
          class:list={[
            'block text-sm py-1 border-l-2 border-transparent transition-colors duration-150 no-underline',
            heading.depth === 2 ? 'pl-3 text-gray-600 hover:text-indigo-600 hover:border-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 dark:hover:border-indigo-400'
              : 'pl-6 text-[0.8125rem] text-gray-500 hover:text-indigo-600 hover:border-indigo-600 dark:text-gray-500 dark:hover:text-indigo-400 dark:hover:border-indigo-400',
          ]}
        >
          {heading.text}
        </a>
      </li>
    ))}
  </ul>
</nav>
