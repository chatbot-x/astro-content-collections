---
import ThemeToggle from './ThemeToggle.astro';
---

<nav aria-label="Main navigation" class="bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-800 dark:to-purple-900 shadow-lg" data-pagefind-ignore>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="h-8 w-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5z" />
          <path d="M2 17l10 5 10-5" />
          <path d="M2 12l10 5 10-5" />
        </svg>
        <span class="text-xl font-bold text-white tracking-tight">isHistory</span>
      </div>
      <div class="hidden sm:flex items-center gap-6">
        <a href="/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium">Home</a>
        <a href="/blog/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium">Blog</a>
        <a href="/series/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium">Series</a>
        <a href="/about/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium">About</a>
        <a href="https://docs.astro.build" target="_blank" rel="noopener noreferrer" class="text-indigo-100 hover:text-white transition-colors font-medium">Docs</a>
        <div class="ml-2 border-l border-indigo-400/40 pl-4 flex items-center gap-2">
          <button
            id="search-btn"
            type="button"
            aria-label="Search"
            class="inline-flex h-9 items-center gap-2 rounded-lg border border-indigo-400/40 bg-white/10 px-3 text-sm text-indigo-100 hover:bg-white/20 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-white/50"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden md:inline">Search</span>
            <kbd class="hidden md:inline-flex items-center rounded border border-indigo-400/40 px-1.5 py-0.5 text-[10px] font-mono text-indigo-200">⌘K</kbd>
          </button>
          <ThemeToggle mode="desktop" />
        </div>
      </div>
      <!-- Mobile: search + theme toggle + hamburger -->
      <div class="flex items-center gap-2 sm:hidden">
        <button
          id="search-btn-mobile"
          type="button"
          aria-label="Search"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-indigo-100 hover:text-white hover:bg-white/10 transition-colors"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <ThemeToggle mode="mobile" />
        <button id="mobile-menu-btn" type="button" aria-label="Open menu" class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-indigo-100 hover:text-white hover:bg-white/10 transition-colors">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden pb-4">
      <div class="flex flex-col gap-2">
        <!-- FIX: Added data-astro-prefetch to mobile nav links for consistency
             with desktop links, so mobile users on slower connections also benefit
             from prefetching. -->
        <a href="/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium py-2">Home</a>
        <a href="/blog/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium py-2">Blog</a>
        <a href="/series/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium py-2">Series</a>
        <a href="/about/" data-astro-prefetch class="text-indigo-100 hover:text-white transition-colors font-medium py-2">About</a>
        <a href="https://docs.astro.build" target="_blank" rel="noopener noreferrer" class="text-indigo-100 hover:text-white transition-colors font-medium py-2">Docs</a>
      </div>
    </div>
  </div>
</nav>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    const controller = new AbortController();
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    }, { signal: controller.signal });

    // Close menu when a nav link is clicked (better UX on mobile)
    const navLinks = menu.querySelectorAll('a');
    navLinks.forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      }, { signal: controller.signal });
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
      }
    }, { signal: controller.signal });

    // Return cleanup function for View Transitions
    return () => controller.abort();
  }

  // Store cleanup function to prevent listener leaks on View Transitions
  let cleanup: (() => void) | undefined;

  function reInitMobileMenu() {
    cleanup?.();
    cleanup = initMobileMenu();
  }

  // astro:page-load fires on both initial load AND after View Transitions swaps
  document.addEventListener('astro:page-load', reInitMobileMenu);
</script>
