---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 dark:bg-black text-gray-400 py-12" data-pagefind-ignore>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">isHistory</h3>
        <p class="text-sm leading-relaxed text-gray-300 mb-1">Mapping the digital past — no code required.</p>
        <p class="text-sm leading-relaxed">A curated archive of the human stories behind technology.</p>
      </div>
      <nav aria-label="Footer navigation">
        <h3 class="text-white font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog/" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/series/" class="hover:text-white transition-colors">Series</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
          <li><a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Astro</a></li>
          <li><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">TailwindCSS</a></li>
        </ul>
      </nav>
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Explore</h3>
        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">AI History</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Technology</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Biographies</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Computing</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Internet</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Open Source</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Deep Dives</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Profiles</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Events</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Dark Mode</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Full-Text Search</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">TypeScript</span>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-gray-800 pt-8 text-center text-sm">
      <p>&copy; {currentYear} isHistory. Mapping the Digital Past.</p>
    </div>
  </div>
</footer>
