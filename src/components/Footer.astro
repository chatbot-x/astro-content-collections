---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 dark:bg-black text-gray-400 py-12" data-pagefind-ignore>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Astro Project</h3>
        <p class="text-sm leading-relaxed">
          A modern static site built with Astro v6 and styled entirely with TailwindCSS v4 utility classes. Features dark mode, AI-ready SEO, full-text search, and type-safe content collections.
        </p>
      </div>
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog/" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/projects/" class="hover:text-white transition-colors">Projects</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
          <li><a href="https://astro.build" target="_blank" class="hover:text-white transition-colors">Astro</a></li>
          <li><a href="https://tailwindcss.com" target="_blank" class="hover:text-white transition-colors">TailwindCSS</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Tech Stack</h3>
        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Astro v6</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">TailwindCSS v4</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Content Collections</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">seo-graph</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Pagefind</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">OG Images</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">rehype-callouts</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Dark Mode</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">TypeScript</span>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-gray-800 pt-8 text-center text-sm">
      <p>&copy; {currentYear} Astro Project. Built with Astro & TailwindCSS.</p>
    </div>
  </div>
</footer>
