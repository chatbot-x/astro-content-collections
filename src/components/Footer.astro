---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 dark:bg-black text-gray-400" data-pagefind-ignore>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Main footer grid -->
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4 py-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <svg class="h-7 w-7 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
          <span class="text-xl font-bold text-white tracking-tight">isHistory</span>
        </div>
        <p class="text-sm leading-relaxed text-gray-400">
          Mapping the digital past — no code required. A curated archive of the human stories behind technology: how ideas sparked, why systems failed or succeeded, and the people who shaped our digital world.
        </p>
      </div>

      <!-- Navigate -->
      <nav aria-label="Footer navigation">
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Navigate</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog/" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/series/" class="hover:text-white transition-colors">Series</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
        </ul>
      </nav>

      <!-- Series -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Series</h3>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="/series/minds-and-machines/" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="h-4 w-4 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
              Minds &amp; Machines
            </a>
          </li>
        </ul>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">75 articles across three tracks — Articles, Profiles, and Events — covering the full history of AI.</p>
      </div>

      <!-- Topics -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Topics</h3>
        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">AI History</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Computing</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Internet</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Biographies</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Deep Learning</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Cybernetics</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Expert Systems</span>
          <span class="rounded-full bg-gray-800 dark:bg-gray-900 px-3 py-1 text-xs font-medium text-gray-300">Neural Networks</span>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>&copy; {currentYear} isHistory. Mapping the Digital Past.</p>
      <div class="flex items-center gap-4">
        <a href="/robots.txt" class="hover:text-gray-300 transition-colors">Robots</a>
        <span class="text-gray-700">|</span>
        <a href="/llms-full.txt" class="hover:text-gray-300 transition-colors">llms.txt</a>
        <span class="text-gray-700">|</span>
        <a href="/blog/rss.xml" class="hover:text-gray-300 transition-colors flex items-center gap-1">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 014.36 0 2.18 2.18 0 01-4.36 0zM2 14.64C2 9.84 5.84 6 10.64 6v2.8a5.84 5.84 0 00-5.84 5.84H2zm0-5.14C2 6.28 6.28 2 11.5 2v2.8a6.7 6.7 0 00-6.7 6.7H2z"/></svg>
          RSS
        </a>
      </div>
    </div>
  </div>
</footer>
