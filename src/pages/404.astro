---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist, has been moved, or the URL may be incorrect. Try browsing our blog or projects instead."
  pageType="page"
>
  <section class="py-24 sm:py-32 bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-950 dark:to-indigo-950/50 min-h-[60vh] flex items-center">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-base font-semibold text-indigo-600 dark:text-indigo-400">404</p>
      <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">
        Page not found
      </h1>
      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        Sorry, the page you're looking for doesn't exist or has been moved. Check the URL for typos, or head back to the homepage.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center rounded-xl bg-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-indigo-500/30 transition-all hover:bg-indigo-700 hover:shadow-xl hover:shadow-indigo-500/40 hover:-translate-y-0.5 dark:bg-indigo-500 dark:shadow-indigo-500/20 dark:hover:bg-indigo-400"
        >
          Go Home
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center rounded-xl border-2 border-indigo-200 bg-white px-8 py-3.5 text-base font-semibold text-indigo-600 transition-all hover:border-indigo-300 hover:bg-indigo-50 hover:-translate-y-0.5 dark:border-indigo-700 dark:bg-gray-800 dark:text-indigo-400 dark:hover:border-indigo-600 dark:hover:bg-gray-700"
        >
          Browse Blog
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
