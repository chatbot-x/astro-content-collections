---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const contentConfigCode = `// src/content.config.ts
import { defineCollection, z } from 'astro:content';
import { glob } from 'astro/loaders';

const blog = defineCollection({
  loader: glob({ pattern: '**/*.{md,mdx}', base: './src/content/blog' }),
  schema: z.object({
    title: z.string(),
    description: z.string(),
    pubDate: z.coerce.date(),
    author: z.string().default('Astro Team'),
    tags: z.array(z.string()).default([]),
    draft: z.boolean().default(false),
  }),
});

const projects = defineCollection({
  loader: glob({ pattern: '**/*.{md,mdx}', base: './src/content/projects' }),
  schema: z.object({
    title: z.string(),
    description: z.string(),
    startDate: z.coerce.date(),
    status: z.enum(['active', 'completed', 'archived']),
    techStack: z.array(z.string()).default([]),
    featured: z.boolean().default(false),
  }),
});

export const collections = { blog, projects };`;

const projectStructureCode = `astro-project/
├── public/              # Static assets
│   └── favicon.svg
├── src/
│   ├── components/      # Reusable UI components
│   │   ├── FeatureCard.astro
│   │   ├── Features.astro
│   │   ├── Footer.astro
│   │   ├── Hero.astro
│   │   ├── LatestPosts.astro
│   │   ├── Navbar.astro
│   │   └── ThemeToggle.astro
│   ├── content/         # Content Collections
│   │   ├── blog/        # Blog posts (Markdown)
│   │   └── projects/    # Project entries (Markdown)
│   ├── layouts/         # Page layouts
│   │   ├── BlogPost.astro
│   │   ├── Layout.astro
│   │   └── ProjectPage.astro
│   ├── pages/           # File-based routing
│   │   ├── blog/
│   │   │   ├── index.astro
│   │   │   ├── [...slug].astro
│   │   │   └── rss.xml.ts
│   │   ├── projects/
│   │   │   ├── index.astro
│   │   │   └── [...slug].astro
│   │   ├── about.astro
│   │   └── index.astro
│   ├── styles/
│   │   └── global.css   # TailwindCSS v4 + Dark mode
│   ├── utils/
│   │   └── schema/      # SEO graph schema builders
│   └── content.config.ts # Collection schemas
├── astro.config.mjs     # Astro + integrations
├── tsconfig.json
└── package.json`;
---

<Layout
  title="About This Project"
  description="Learn about this Astro v6 + TailwindCSS v4 project with type-safe Content Collections, dark mode, and AI-ready SEO."
  pageType="about"
>
  <section class="py-20 sm:py-28 bg-gradient-to-br from-gray-50 to-indigo-50 dark:from-gray-900 dark:to-indigo-950/50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight text-center mb-8">
        About This Project
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed text-center max-w-2xl mx-auto mb-16">
        A reference project showcasing Astro v6 with TailwindCSS v4, type-safe Content Collections, dark mode, and AI-ready SEO — using the native Vite plugin approach.
      </p>

      <div class="space-y-8">
        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600 dark:bg-indigo-900 dark:text-indigo-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </span>
            Astro v6
          </h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Astro is a web framework designed for content-driven websites. Its island architecture sends zero JavaScript by default, hydrating only the interactive components that need it. Version 6 brings improved performance, enhanced content collections with the Content Layer API, and better developer experience with tighter Vite integration. This project leverages Astro's static site generation to produce pre-rendered HTML pages that load instantly in the browser.
          </p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-100 text-cyan-600 dark:bg-cyan-900 dark:text-cyan-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </span>
            TailwindCSS v4
          </h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            TailwindCSS v4 introduces a CSS-first configuration approach, eliminating the need for a JavaScript config file. Instead of tailwind.config.js, you configure themes and custom utilities directly in your CSS using @theme directives. The Vite plugin provides automatic content detection, so you never need to configure the content array. This project uses the @tailwindcss/vite plugin integrated directly into Astro's Vite config for the smoothest developer experience.
          </p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-purple-100 text-purple-600 dark:bg-purple-900 dark:text-purple-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </span>
            Content Collections
          </h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
            This project uses Astro's Content Layer API to manage structured content with type-safe schemas. Two collections are configured — <strong class="text-gray-800 dark:text-gray-200">Blog</strong> and <strong class="text-gray-800 dark:text-gray-200">Projects</strong> — each with Zod-validated frontmatter that provides TypeScript autocompletion and build-time validation.
          </p>
          <div class="bg-gray-900 dark:bg-gray-950 rounded-xl p-5 text-sm font-mono text-gray-300 overflow-x-auto">
            <pre class="leading-relaxed">{contentConfigCode}</pre>
          </div>
        </div>

        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-amber-100 text-amber-600 dark:bg-amber-900 dark:text-amber-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </span>
            Dark Mode
          </h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            This project implements a full 3-mode dark mode system (Light / Dark / System) using a <strong class="text-gray-800 dark:text-gray-200">custom ThemeProvider component</strong>. The theme persists across page loads via localStorage, respects the user's OS preference by default, syncs across browser tabs, and never flashes unstyled content on load. The toggle component in the navigation bar provides quick access to all three modes.
          </p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900 dark:text-emerald-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </span>
            AI-Ready SEO
          </h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Built with <strong class="text-gray-800 dark:text-gray-200">@jdevalk/astro-seo-graph</strong> by Joost de Valk (Yoast SEO founder), this project generates a linked Schema.org knowledge graph with JSON-LD structured data on every page. It includes automatic generation of llms.txt for LLM discoverability, build-time SEO validators (H1, unique titles, image alt, metadata length, internal links), AI crawler blocking via astro-ai-robots-txt, and support for IndexNow instant re-indexing.
          </p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-gray-900 p-8 shadow-sm border border-gray-100 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900 dark:text-emerald-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </span>
            Project Structure
          </h2>
          <div class="bg-gray-900 dark:bg-gray-950 rounded-xl p-6 text-sm font-mono text-gray-300 overflow-x-auto">
            <pre class="leading-relaxed">{projectStructureCode}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
