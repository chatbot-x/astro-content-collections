---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';
import { computeReadingTime } from '../../utils/readingTime';
import '../../styles/global.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => !data.draft);
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Compute reading time from raw body
const readingStats = entry.body ? computeReadingTime(entry.body) : null;

// OG image URL for this post
// FIX: Added .png extension so social media crawlers recognize it as an image.
// The OG image endpoint returns a PNG response but without .png extension,
// some crawlers (e.g., Twitter/X card validator) may not detect it as an image.
const ogImageUrl = `/og/blog/${entry.id}.png`;
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  pageType="blogPost"
  publishDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  featureImageUrl={entry.data.heroImage || ogImageUrl}
  category={entry.data.tags?.[0]}
  wordCount={readingStats?.words}
  articleType={entry.data.articleType}
>
  <Navbar />

  <div class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-950 dark:to-indigo-950/50 min-h-screen">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-8">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Blog
      </a>
    </div>

    <BlogPost
      title={entry.data.title}
      description={entry.data.description}
      pubDate={entry.data.pubDate}
      updatedDate={entry.data.updatedDate}
      author={entry.data.author}
      tags={entry.data.tags}
      heroImage={entry.data.heroImage}
      readingTime={readingStats?.text}
      wordCount={readingStats?.words}
    >
      <Content />
    </BlogPost>
  </div>

  <Footer />
</Layout>
