---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — Astro + TailwindCSS">
  <Navbar />

  <section class="py-16 sm:py-24 bg-gradient-to-br from-indigo-50 via-white to-purple-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight">
          Blog
        </h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Thoughts, tutorials, and insights about Astro, TailwindCSS, and modern web development.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {allPosts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });

          return (
            <a href={`/blog/${post.id}`} class="group">
              <article class="h-full rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                <div class="mb-4 flex items-center gap-2 text-sm text-gray-500">
                  <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                  <span class="text-gray-300">·</span>
                  <span>{post.data.author}</span>
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          );
        })}
      </div>

      {allPosts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-gray-500 text-lg">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>
