---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { computeReadingTime } from '../../utils/readingTime';
import { SITE_URL } from '../../utils/site';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Build listing items for schema ItemList
const listingItems = allPosts.map((post) => ({
  title: post.data.title,
  url: `${SITE_URL}/blog/${post.id}/`,
}));
---

<Layout
  title="Blog — Articles & Tutorials"
  description="Thoughts, tutorials, and insights about Astro, TailwindCSS, and modern web development."
  pageType="blogListing"
  listingItems={listingItems}
>
  <section class="py-16 sm:py-24 bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-950 dark:to-indigo-950/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">
          Blog
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Thoughts, tutorials, and insights about Astro, TailwindCSS, and modern web development.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {allPosts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });

          const readingStats = post.body ? computeReadingTime(post.body) : null;

          return (
            <a href={`/blog/${post.id}/`} class="group">
              <article class="h-full rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                <div class="mb-4 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                  <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                  <span class="text-gray-300 dark:text-gray-600">·</span>
                  <span>{post.data.author}</span>
                  {readingStats && (
                    <>
                      <span class="text-gray-300 dark:text-gray-600">·</span>
                      <span>{readingStats.text}</span>
                    </>
                  )}
                </div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4 line-clamp-3">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-600 dark:bg-indigo-950 dark:text-indigo-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          );
        })}
      </div>

      {allPosts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-gray-500 dark:text-gray-400 text-lg">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</Layout>
