---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import LatestPosts from '../components/LatestPosts.astro';
import { getCollection } from 'astro:content';

// Get active series with articles for the featured section
const allProjects = await getCollection('projects');
const activeSeries = allProjects
  .filter((entry) => !entry.id.includes('/'))
  .filter((entry) => entry.data.status === 'active' || entry.data.featured)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  })
  .slice(0, 3);
---

<Layout
  title="isHistory — Mapping the Digital Past | Tech History Archive"
  description="isHistory is a curated digital archive of the stories behind technology — how ideas sparked, why systems failed or succeeded, and the people who shaped the digital age without ever showing a single line of code. From the first bug to the last-minute Tech breakthrough, we document the How, Why and Who of computing history."
  pageType="home"
>
  <Hero />

  <!-- FIX: Editorial intro section — adds keyword-rich content for SEO density.
       Explains the site's purpose in natural language so search engines understand
       the topical focus without needing to crawl the full article archive. -->
  <section class="py-16 sm:py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        From the origins of artificial intelligence in <em>Minds &amp; Machines</em>, to the birth of the internet in <em>The Wire</em>, to the corporate battles of <em>Console Wars</em> — isHistory traces the people, events, and ideas that defined the digital age. Every article is a self-contained story, meticulously researched and written for curious readers who want to understand not just what happened, but why it mattered.
      </p>
    </div>
  </section>

  <!-- FIX: Featured series section — surfaces the active series on the homepage,
       adding content density and internal links for SEO crawlers. -->
  {activeSeries.length > 0 && (
    <section class="py-16 sm:py-20 bg-gradient-to-br from-gray-50 to-indigo-50 dark:from-gray-900 dark:to-indigo-950/50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
            Featured Series
          </h2>
          <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
            Deep-dive narratives into the history of technology.
          </p>
        </div>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {activeSeries.map((entry) => {
            const isUpcoming = entry.data.status === 'upcoming';
            const linkHref = isUpcoming ? '#' : `/series/${entry.id}/`;
            return (
              <a href={linkHref} class="group">
                <article class="h-full rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col">
                  {entry.data.tagline && (
                    <p class="text-indigo-600 dark:text-indigo-400 text-sm font-semibold mb-2">
                      {entry.data.tagline}
                    </p>
                  )}
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
                    {entry.data.title}
                  </h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4 line-clamp-3 flex-grow">
                    {entry.data.hook || entry.data.description}
                  </p>
                  {(entry.data.articleCount || entry.data.tracks) && (
                    <div class="flex flex-wrap gap-4 mt-auto text-sm text-gray-500 dark:text-gray-500 mb-3">
                      {entry.data.articleCount && (
                        <span>{entry.data.articleCount} articles</span>
                      )}
                      {entry.data.tracks && (
                        <span>{entry.data.tracks.length} tracks</span>
                      )}
                    </div>
                  )}
                  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 group-hover:text-indigo-800 dark:group-hover:text-indigo-300 transition-colors">
                    Explore series
                    <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </span>
                </article>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <Features />
  <LatestPosts />
</Layout>
