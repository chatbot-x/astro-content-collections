---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import LatestPosts from '../components/LatestPosts.astro';
import { getCollection } from 'astro:content';

// Get active series with articles for the featured section
const allProjects = await getCollection('projects');
const activeSeries = allProjects
  .filter((entry) => !entry.id.includes('/'))
  .filter((entry) => entry.data.status === 'active' || entry.data.featured)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  })
  .slice(0, 3);

// Get upcoming series for secondary display
const upcomingSeries = allProjects
  .filter((entry) => !entry.id.includes('/'))
  .filter((entry) => entry.data.status === 'upcoming' && !entry.data.featured)
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());
---

<Layout
  title="isHistory — Mapping the Digital Past | Tech History Archive"
  description="isHistory is a curated digital archive of the stories behind technology — how ideas sparked, why systems failed or succeeded, and the people who shaped the digital age without ever showing a single line of code. From the first bug to the last-minute Tech breakthrough, we document the How, Why and Who of computing history."
  pageType="home"
>
  <Hero />

  <!-- FIX: Editorial intro section — adds keyword-rich content for SEO density.
       Explains the site's purpose in natural language so search engines understand
       the topical focus without needing to crawl the full article archive. -->
  <section class="py-16 sm:py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        From the origins of artificial intelligence in <em>Minds &amp; Machines</em>, to the birth of the internet in <em>The Wire</em>, to the corporate battles of <em>Console Wars</em> — isHistory traces the people, events, and ideas that defined the digital age. Every article is a self-contained story, meticulously researched and written for curious readers who want to understand not just what happened, but why it mattered.
      </p>
    </div>
  </section>

  <Features />

  <!-- FIX: Featured series section — surfaces the active series on the homepage,
       adding content density and internal links for SEO crawlers.
       MOVED after "Why isHistory?" for better narrative flow. -->
  {activeSeries.length > 0 && (
    <section class="py-20 sm:py-28 bg-white dark:bg-gray-950">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-semibold text-indigo-600 dark:bg-indigo-950 dark:text-indigo-400 mb-4">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Featured Series
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
            Deep-Dive Narratives
          </h2>
          <p class="mt-3 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Explore the history of technology through immersive, multi-article series — no code, just the human journey.
          </p>
        </div>

        <!-- Featured series: large hero card for the primary active series -->
        {activeSeries.map((entry, index) => {
          const isUpcoming = entry.data.status === 'upcoming';
          const linkHref = isUpcoming ? '#' : `/series/${entry.id}/`;
          const isFeatured = index === 0;

          if (isFeatured) {
            return (
              <a href={linkHref} class="group block mb-10">
                <article class="relative overflow-hidden rounded-3xl border border-indigo-100 dark:border-indigo-900/50 bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-indigo-950/40 dark:via-gray-900 dark:to-purple-950/30 p-8 sm:p-12 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/10 dark:hover:shadow-indigo-500/5 hover:-translate-y-1">
                  {/* Decorative background elements */}
                  <div class="absolute top-0 right-0 -mt-6 -mr-6 h-48 w-48 rounded-full bg-indigo-200/40 dark:bg-indigo-800/20 blur-3xl"></div>
                  <div class="absolute bottom-0 left-0 -mb-6 -ml-6 h-36 w-36 rounded-full bg-purple-200/40 dark:bg-purple-800/20 blur-3xl"></div>

                  <div class="relative flex flex-col lg:flex-row lg:items-center lg:gap-12">
                    {/* Left: Content */}
                    <div class="flex-1">
                      {/* Status badge */}
                      <div class="flex items-center gap-3 mb-4">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-400">
                          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 animate-pulse"></span>
                          Now Publishing
                        </span>
                        {entry.data.tagline && (
                          <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400">
                            {entry.data.tagline}
                          </span>
                        )}
                      </div>

                      {/* Title */}
                      <h3 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-900 dark:text-white mb-4 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-tight">
                        {entry.data.title}
                      </h3>

                      {/* Hook / Description */}
                      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6 max-w-2xl">
                        {entry.data.hook || entry.data.description}
                      </p>

                      {/* Stats row */}
                      <div class="flex flex-wrap items-center gap-4 sm:gap-6 mb-6">
                        {entry.data.articleCount && (
                          <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                            <svg class="h-5 w-5 text-indigo-500 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                            <span class="font-semibold">{entry.data.articleCount} articles</span>
                          </div>
                        )}
                        {entry.data.tracks && entry.data.tracks.length > 0 && (
                          <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                            <svg class="h-5 w-5 text-purple-500 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
                            <span class="font-semibold">{entry.data.tracks.length} tracks</span>
                          </div>
                        )}
                        {entry.data.wordCount && (
                          <div class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                            <svg class="h-5 w-5 text-cyan-500 dark:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" /></svg>
                            <span class="font-semibold">{entry.data.wordCount}</span>
                          </div>
                        )}
                      </div>

                      {/* Track badges */}
                      {entry.data.tracks && entry.data.tracks.length > 0 && (
                        <div class="flex flex-wrap gap-2 mb-6">
                          {entry.data.tracks.map((track) => (
                            <span class="inline-flex items-center gap-1.5 rounded-lg bg-white/80 dark:bg-gray-800/80 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 backdrop-blur-sm">
                              <span class="font-mono text-xs text-indigo-600 dark:text-indigo-400">{track.code}</span>
                              {track.name}
                            </span>
                          ))}
                        </div>
                      )}

                      {/* CTA */}
                      <span class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all group-hover:bg-indigo-700 group-hover:shadow-xl group-hover:shadow-indigo-500/30 group-hover:-translate-y-0.5 dark:bg-indigo-500 dark:shadow-indigo-500/20 dark:group-hover:bg-indigo-400">
                        Explore series
                        <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                      </span>
                    </div>

                    {/* Right: Acts timeline (if available) */}
                    {entry.data.acts && entry.data.acts.length > 0 && (
                      <div class="mt-8 lg:mt-0 lg:w-80 flex-shrink-0">
                        <div class="rounded-2xl border border-gray-200/80 dark:border-gray-700/80 bg-white/60 dark:bg-gray-800/60 backdrop-blur-sm p-6">
                          <h4 class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Series Arc</h4>
                          <div class="space-y-3">
                            {entry.data.acts.map((act, actIndex) => (
                              <div class="flex items-start gap-3">
                                <div class="flex-shrink-0 mt-0.5 flex h-7 w-7 items-center justify-center rounded-full bg-indigo-100 text-xs font-bold text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-400">
                                  {act.roman}
                                </div>
                                <div>
                                  <p class="text-sm font-semibold text-gray-900 dark:text-white">{act.name}</p>
                                  <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">{act.description}</p>
                                </div>
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </article>
              </a>
            );
          }

          return null;
        })}

        {/* Upcoming series: smaller cards in a row */}
        {upcomingSeries.length > 0 && (
          <div class="grid gap-8 sm:grid-cols-2">
            {upcomingSeries.map((entry) => {
              const linkHref = entry.data.status === 'upcoming' ? '#' : `/series/${entry.id}/`;
              return (
                <a href={linkHref} class="group">
                  <article class="h-full rounded-2xl border border-gray-200 dark:border-gray-800 bg-gradient-to-br from-gray-50 to-white dark:from-gray-900 dark:to-gray-900/80 p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-indigo-200 dark:hover:border-indigo-800 flex flex-col">
                    {/* Status badge */}
                    <div class="flex items-center gap-2 mb-4">
                      <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        Coming Soon
                      </span>
                      {entry.data.startDate && (
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          {entry.data.startDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                        </span>
                      )}
                    </div>

                    {/* Tagline */}
                    {entry.data.tagline && (
                      <p class="text-indigo-600 dark:text-indigo-400 text-sm font-semibold mb-1">
                        {entry.data.tagline}
                      </p>
                    )}

                    {/* Title */}
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
                      {entry.data.title}
                    </h3>

                    {/* Description */}
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-5 flex-grow">
                      {entry.data.hook || entry.data.description}
                    </p>

                    {/* Stats */}
                    {(entry.data.articleCount || entry.data.wordCount) && (
                      <div class="flex flex-wrap gap-4 text-sm text-gray-500 dark:text-gray-400 mb-4">
                        {entry.data.articleCount && (
                          <span class="flex items-center gap-1.5">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                            {entry.data.articleCount} articles
                          </span>
                        )}
                        {entry.data.wordCount && (
                          <span class="flex items-center gap-1.5">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" /></svg>
                            {entry.data.wordCount}
                          </span>
                        )}
                      </div>
                    )}

                    {/* CTA */}
                    <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-600 dark:text-indigo-400 group-hover:text-indigo-800 dark:group-hover:text-indigo-300 transition-colors">
                      Learn more
                      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                    </span>
                  </article>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <LatestPosts />
</Layout>
