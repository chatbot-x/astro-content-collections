---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => {
    // Featured first, then by start date descending
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  });

const statusColors: Record<string, string> = {
  active: 'bg-emerald-50 text-emerald-700 ring-emerald-100',
  completed: 'bg-blue-50 text-blue-700 ring-blue-100',
  archived: 'bg-gray-50 text-gray-600 ring-gray-200',
};
---

<Layout title="Projects — Astro + TailwindCSS">
  <Navbar />

  <section class="py-16 sm:py-24 bg-gradient-to-br from-purple-50 via-white to-cyan-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight">
          Projects
        </h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          A showcase of projects built with Astro and the modern web stack. Each project demonstrates different capabilities of the ecosystem.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {allProjects.map((project) => {
          const statusColor = statusColors[project.data.status] || statusColors.active;
          const formattedStart = project.data.startDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

          return (
            <a href={`/projects/${project.id}`} class="group">
              <article class="h-full rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                <div class="mb-4 flex items-center gap-2">
                  <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${statusColor}`}>
                    {project.data.status.charAt(0).toUpperCase() + project.data.status.slice(1)}
                  </span>
                  {project.data.featured && (
                    <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-100">
                      Featured
                    </span>
                  )}
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-purple-600 transition-colors">
                  {project.data.title}
                </h2>
                <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3">
                  {project.data.description}
                </p>
                <div class="mt-auto">
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {project.data.techStack.map((tech) => (
                      <span class="inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-600">
                        {tech}
                      </span>
                    ))}
                  </div>
                  <div class="text-xs text-gray-400">{formattedStart}</div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
