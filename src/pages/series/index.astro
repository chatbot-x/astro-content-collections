---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../utils/site';
import { statusColors, statusLabels } from '../../utils/statusColors';

// Only show root-level series entries (not individual articles inside subfolders)
// A series entry is a root-level .md file; articles live inside subfolders like
// minds-and-machines/a1-the-ancient-dream.md
const allEntries = await getCollection('projects');
const seriesEntries = allEntries
  .filter((entry) => !entry.id.includes('/')) // root-level only
  .filter((entry) => entry.data.status !== 'archived')
  .sort((a, b) => {
    // Sort: active first, then upcoming, then completed
    const statusOrder: Record<string, number> = { active: 0, upcoming: 1, completed: 2, archived: 3 };
    const aOrder = statusOrder[a.data.status] ?? 99;
    const bOrder = statusOrder[b.data.status] ?? 99;
    if (aOrder !== bOrder) return aOrder - bOrder;
    // Within same status, featured first
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    // Then by start date descending
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  });

const listingItems = seriesEntries.map((entry) => ({
  title: entry.data.title,
  url: `${SITE_URL}/series/${entry.id}/`,
}));
---

<Layout
  title="Series"
  description="Deep dives into the human stories behind technology. Each series is a self-contained narrative — no code, just decisions, debates, and the people who shaped our digital world."
  pageType="projectListing"
  listingItems={listingItems}
>
  <section class="py-16 sm:py-24 bg-gradient-to-br from-purple-50 via-white to-cyan-50 dark:from-gray-900 dark:via-gray-950 dark:to-cyan-950/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">
          Series
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Deep dives into the human stories behind technology.
        </p>
        <p class="mt-2 text-base text-gray-500 dark:text-gray-500 max-w-2xl mx-auto">
          Each series is a self-contained narrative — no code, just decisions, debates, and the people who shaped our digital world. New series published regularly.
        </p>
      </div>

      <!-- Series Grid -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {seriesEntries.map((entry) => {
          const statusColor = statusColors[entry.data.status] || statusColors.active;
          const statusLabel = statusLabels[entry.data.status] || entry.data.status;
          const isUpcoming = entry.data.status === 'upcoming';
          const linkHref = isUpcoming ? '#' : `/series/${entry.id}/`;

          return (
            <a href={linkHref} class={`group ${isUpcoming ? 'cursor-default' : ''}`} {...(isUpcoming ? { 'aria-disabled': 'true' } : {})}>
              <article class="h-full rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col">
                <!-- Header: Title + Status -->
                <div class="mb-4 flex items-start justify-between gap-3">
                  <h2 class={`text-xl font-bold text-gray-900 dark:text-white leading-snug ${!isUpcoming ? 'group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors' : ''}`}>
                    {entry.data.title}
                  </h2>
                  <span class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${statusColor}`}>
                    {statusLabel}
                  </span>
                </div>

                <!-- Tagline -->
                {entry.data.tagline && (
                  <p class="text-purple-600 dark:text-purple-400 text-sm font-medium mb-2">
                    {entry.data.tagline}
                  </p>
                )}

                <!-- Description -->
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4 line-clamp-3 flex-grow">
                  {entry.data.hook || entry.data.description}
                </p>

                <!-- Metadata -->
                {(entry.data.articleCount || entry.data.wordCount) && (
                  <div class="flex flex-wrap gap-4 mt-auto text-sm text-gray-500 dark:text-gray-500 mb-4">
                    {entry.data.articleCount && (
                      <span class="inline-flex items-center gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                        </svg>
                        {entry.data.articleCount} articles
                      </span>
                    )}
                    {entry.data.wordCount && (
                      <span class="inline-flex items-center gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                        {entry.data.wordCount}
                      </span>
                    )}
                  </div>
                )}

                <!-- CTA -->
                <div class="mt-auto pt-2">
                  {isUpcoming ? (
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-400 dark:text-gray-600">
                      Coming soon
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-600 dark:text-purple-400 group-hover:text-purple-800 dark:group-hover:text-purple-300 transition-colors">
                      Explore series
                      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                      </svg>
                    </span>
                  )}
                </div>
              </article>
            </a>
          );
        })}
      </div>

      {seriesEntries.length === 0 && (
        <div class="text-center py-20">
          <p class="text-gray-500 dark:text-gray-400 text-lg">No series yet. Check back soon!</p>
        </div>
      )}

      <!-- Newsletter CTA -->
      <div class="mt-20 rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-800 dark:to-purple-900 p-8 sm:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">Stay in the loop</h2>
        <p class="text-indigo-100 max-w-lg mx-auto mb-6">
          New series announced regularly. Get notified when the next deep dive launches — no spam, just stories.
        </p>
        <a href="/about/" class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-indigo-700 shadow-sm transition-colors hover:bg-indigo-50">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Get notified
        </a>
      </div>
    </div>
  </section>
</Layout>
