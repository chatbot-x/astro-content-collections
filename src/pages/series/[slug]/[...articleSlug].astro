---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('projects');
  const seriesEntries = allEntries.filter((entry) => !entry.id.includes('/'));
  const articleEntries = allEntries.filter((entry) => entry.id.includes('/'));

  return articleEntries.map((article) => {
    const seriesSlug = article.id.split('/')[0];
    const articleSlug = article.id.split('/').pop();
    const seriesEntry = seriesEntries.find((s) => s.id === seriesSlug);

    return {
      params: { slug: seriesSlug, articleSlug },
      props: { article, seriesEntry, allEntries },
    };
  });
}

const { article, seriesEntry, allEntries } = Astro.props;
const { Content } = await render(article);

const seriesSlug = article.id.split('/')[0];
const currentTrack = article.data.track || 'articles';

// All articles in this series — sorted by track order then episodeNumber
const trackOrder: Record<string, number> = { articles: 0, profiles: 1, events: 2 };
const allSeriesArticles = allEntries
  .filter((e: any) => e.id.startsWith(`${seriesSlug}/`) && e.id.includes('/'))
  .sort((a: any, b: any) => {
    const aTrack = trackOrder[a.data.track ?? 'articles'] ?? 99;
    const bTrack = trackOrder[b.data.track ?? 'articles'] ?? 99;
    if (aTrack !== bTrack) return aTrack - bTrack;
    return (a.data.episodeNumber ?? 0) - (b.data.episodeNumber ?? 0);
  });

// Group by track
const articlesByTrack: Record<string, typeof allSeriesArticles> = {};
for (const entry of allSeriesArticles) {
  const track = entry.data.track || 'articles';
  if (!articlesByTrack[track]) articlesByTrack[track] = [];
  articlesByTrack[track].push(entry);
}

// Track-aware prev/next: navigate within the SAME track
const sameTrackArticles = articlesByTrack[currentTrack] || [];
const trackIndex = sameTrackArticles.findIndex((e: any) => e.id === article.id);
const prevInTrack = trackIndex > 0 ? sameTrackArticles[trackIndex - 1] : null;
const nextInTrack = trackIndex < sameTrackArticles.length - 1 ? sameTrackArticles[trackIndex + 1] : null;
const hasTrackNav = prevInTrack || nextInTrack;

// ──── Read alongside: curated connections from connectsTo ────
// Same-track entries are allowed (e.g. P7↔P10 Minsky/Rosenblatt rivalry,
// E14→E13 AlexNet/ImageNet) — only editorially meaningful thematic links,
// never sequential prev/next which is handled by the track navigation above.
const connectsToSlugs = (article.data.connectsTo || []) as string[];
const readAlongside = connectsToSlugs
  .map((slug) => allSeriesArticles.find((a) => a.id === `${seriesSlug}/${slug}` || a.id.endsWith(slug)))
  .filter((a): a is typeof allSeriesArticles[number] => !!a);

// IDs of articles already shown in "Read alongside" (to deduplicate from "Other tracks")
const alongsideIds = new Set(readAlongside.map((a) => a.id));

// Cross-track articles NOT already shown in "Read alongside"
const otherTracks = Object.entries(articlesByTrack)
  .filter(([track]) => track !== currentTrack)
  .map(([track, articles]) => ({
    track,
    articles: articles.filter((a) => !alongsideIds.has(a.id)),
  }))
  .filter(({ articles }) => articles.length > 0);

const trackLabels: Record<string, string> = { articles: 'A-Series', profiles: 'P-Series', events: 'E-Series' };
const trackTheme: Record<string, { bg: string; text: string; ring: string; border: string; hoverBg: string }> = {
  articles: {
    bg: 'bg-indigo-50 dark:bg-indigo-950/50',
    text: 'text-indigo-700 dark:text-indigo-300',
    ring: 'ring-indigo-200 dark:ring-indigo-800',
    border: 'border-indigo-200 dark:border-indigo-800',
    hoverBg: 'hover:bg-indigo-100 dark:hover:bg-indigo-900/50',
  },
  profiles: {
    bg: 'bg-emerald-50 dark:bg-emerald-950/50',
    text: 'text-emerald-700 dark:text-emerald-300',
    ring: 'ring-emerald-200 dark:ring-emerald-800',
    border: 'border-emerald-200 dark:border-emerald-800',
    hoverBg: 'hover:bg-emerald-100 dark:hover:bg-emerald-900/50',
  },
  events: {
    bg: 'bg-amber-50 dark:bg-amber-950/50',
    text: 'text-amber-700 dark:text-amber-300',
    ring: 'ring-amber-200 dark:ring-amber-800',
    border: 'border-amber-200 dark:border-amber-800',
    hoverBg: 'hover:bg-amber-100 dark:hover:bg-amber-900/50',
  },
};

const currentTheme = trackTheme[currentTrack] || trackTheme.articles;
const currentTrackLabel = trackLabels[currentTrack] || currentTrack;

const ogImageUrl = `/og/projects/${article.id}.png`;
---

<Layout
  title={article.data.title}
  description={article.data.description}
  pageType="blogPost"
  publishDate={article.data.startDate}
  featureImageUrl={article.data.heroImage || ogImageUrl}
  category={currentTrackLabel}
  wordCount={0}
  articleType="Article"
>
  <div class="bg-gradient-to-br from-purple-50 via-white to-cyan-50 dark:from-gray-900 dark:via-gray-950 dark:to-cyan-950/50 min-h-screen">
    <!-- Breadcrumb -->
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-8">
      <nav aria-label="Breadcrumb" class="flex items-center gap-1.5 text-sm flex-wrap">
        <a href="/" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors">Home</a>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="/series/" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors">Series</a>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href={`/series/${seriesSlug}/`} class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors truncate max-w-[200px]">
          {seriesEntry?.data.title || seriesSlug}
        </a>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-gray-600 dark:text-gray-400 truncate max-w-[200px]">{article.data.title}</span>
      </nav>
    </div>

    <!-- Article Content -->
    <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12" data-pagefind-body>
      <!-- Article Header -->
      <header class="mb-10">
        <!-- Track badge + tag -->
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${currentTheme.bg} ${currentTheme.text} ${currentTheme.ring}`}>
            {currentTrackLabel}
          </span>
          {article.data.tag && (
            <span class="inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-100 dark:bg-purple-950 dark:text-purple-300 dark:ring-purple-800">
              {article.data.tag}
            </span>
          )}
        </div>

        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight" data-pagefind-meta="title">
          {article.data.title}
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
          {article.data.description}
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span>{article.data.startDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {seriesEntry && (
            <>
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <span>Part of <a href={`/series/${seriesSlug}/`} class="text-purple-600 dark:text-purple-400 hover:underline">{seriesEntry.data.title}</a></span>
            </>
          )}
        </div>
        {article.data.techStack && article.data.techStack.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {article.data.techStack.map((tech: string) => (
              <span class="inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-100 dark:bg-purple-950 dark:text-purple-300 dark:ring-purple-800">
                {tech}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Article Body -->
      <div class="prose prose-lg prose-indigo prose-headings:font-bold prose-headings:tracking-tight prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline prose-code:font-mono prose-pre:bg-gray-900 prose-pre:text-gray-300 max-w-none dark:prose-invert dark:prose-a:text-indigo-400 dark:prose-headings:text-white dark:prose-code:text-indigo-300 dark:prose-pre:bg-gray-900 [&_h1]:sr-only">
        <Content />
      </div>

      <!-- ─────────────────────────────────────────────── -->
      <!-- Article Navigation (same max-w-3xl container)  -->
      <!-- ─────────────────────────────────────────────── -->

      <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800">

        <!-- Track position indicator -->
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-2.5">
            <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset ${currentTheme.bg} ${currentTheme.text} ${currentTheme.ring}`}>
              {currentTrackLabel}
            </span>
            <span class="text-sm text-gray-500 dark:text-gray-400">
              Article {trackIndex + 1} of {sameTrackArticles.length}
            </span>
          </div>
          <a
            href={`/series/${seriesSlug}/`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors"
          >
            All articles
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Prev/Next in same track -->
        {hasTrackNav && (
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            {prevInTrack ? (
              <a
                href={`/series/${seriesSlug}/${prevInTrack.id.split('/').pop()}/`}
                class="group flex-1 flex items-center gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 transition-all hover:shadow-md hover:border-purple-300 dark:hover:border-purple-700"
              >
                <svg class="shrink-0 h-5 w-5 text-gray-300 dark:text-gray-600 group-hover:text-purple-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                <div class="min-w-0">
                  <div class="text-xs text-gray-400 dark:text-gray-500 mb-0.5">Previous</div>
                  <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors line-clamp-2">{prevInTrack.data.title}</div>
                </div>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block" />
            )}
            {nextInTrack ? (
              <a
                href={`/series/${seriesSlug}/${nextInTrack.id.split('/').pop()}/`}
                class="group flex-1 flex items-center justify-end gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 transition-all hover:shadow-md hover:border-purple-300 dark:hover:border-purple-700 text-right"
              >
                <div class="min-w-0">
                  <div class="text-xs text-gray-400 dark:text-gray-500 mb-0.5">Next</div>
                  <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors line-clamp-2">{nextInTrack.data.title}</div>
                </div>
                <svg class="shrink-0 h-5 w-5 text-gray-300 dark:text-gray-600 group-hover:text-purple-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block" />
            )}
          </div>
        )}

        <!-- ═══════════════════════════════════════════ -->
        <!-- Read alongside (curated cross-track links) -->
        <!-- ═══════════════════════════════════════════ -->
        {readAlongside.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <svg class="h-4 w-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              Read alongside
            </h3>
            <div class="space-y-3">
              {readAlongside.map((a) => {
                const tTrack = a.data.track || 'articles';
                const tLabel = trackLabels[tTrack] || tTrack;
                const tTheme = trackTheme[tTrack] || trackTheme.articles;
                return (
                  <a
                    href={`/series/${seriesSlug}/${a.id.split('/').pop()}/`}
                    class={`group flex items-start gap-4 rounded-xl border ${tTheme.border} ${tTheme.bg} p-4 sm:p-5 transition-all hover:shadow-md`}
                  >
                    <div class="shrink-0 mt-0.5">
                      <span class={`inline-flex h-9 w-9 items-center justify-center rounded-lg ${tTheme.bg} ${tTheme.text}`}>
                        {tTrack === 'profiles' ? (
                          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                        ) : tTrack === 'events' ? (
                          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                        ) : (
                          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                        )}
                      </span>
                    </div>
                    <div class="min-w-0 flex-grow">
                      <div class="flex items-center gap-2 mb-1">
                        <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ring-1 ring-inset ${tTheme.bg} ${tTheme.text} ${tTheme.ring}`}>
                          {tLabel}
                        </span>
                      </div>
                      <h4 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors leading-snug mb-1">
                        {a.data.title}
                      </h4>
                      <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">
                        {a.data.description}
                      </p>
                    </div>
                    <svg class="shrink-0 h-5 w-5 text-gray-300 dark:text-gray-600 group-hover:text-purple-500 transition-colors mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Other tracks (remaining cross-track articles)  -->
        <!-- ═══════════════════════════════════════════════ -->
        {otherTracks.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
              Other tracks in this series
            </h3>
            <div class="space-y-3">
              {otherTracks.map(({ track, articles }) => {
                const tLabel = trackLabels[track] || track;
                const tTheme = trackTheme[track] || trackTheme.articles;
                return (
                  <div class={`rounded-xl border ${tTheme.border} ${tTheme.bg} p-4 sm:p-5`}>
                    <div class="flex items-center justify-between mb-3">
                      <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset ${tTheme.bg} ${tTheme.text} ${tTheme.ring}`}>
                        {tLabel}
                      </span>
                      <span class="text-xs text-gray-400 dark:text-gray-500">
                        {articles.length} article{articles.length !== 1 ? 's' : ''}
                      </span>
                    </div>
                    <div class="space-y-1">
                      {articles.map((a) => (
                        <a
                          href={`/series/${seriesSlug}/${a.id.split('/').pop()}/`}
                          class={`group flex items-center gap-2.5 rounded-lg px-2.5 py-2 -mx-2.5 text-sm ${tTheme.text} ${tTheme.hoverBg} transition-colors`}
                        >
                          <svg class="shrink-0 h-3.5 w-3.5 opacity-40 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                          <span class="truncate font-medium">{a.data.title}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Back to Series -->
        <div class="text-center pt-4">
          <a
            href={`/series/${seriesSlug}/`}
            class="inline-flex items-center gap-2 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-5 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-300 shadow-sm transition-all hover:shadow-md hover:text-purple-600 dark:hover:text-purple-400 hover:border-purple-300 dark:hover:border-purple-700"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Back to {seriesEntry?.data.title || 'Series'}
          </a>
        </div>
      </div>
    </article>
  </div>
</Layout>
