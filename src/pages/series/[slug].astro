---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL } from '../../utils/site';
import { statusColors, statusLabels } from '../../utils/statusColors';

export async function getStaticPaths() {
  const allEntries = await getCollection('projects');
  // Only root-level entries are series landing pages
  const seriesEntries = allEntries.filter((entry) => !entry.id.includes('/'));
  return seriesEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { seriesEntry: entry, allEntries },
  }));
}

const { seriesEntry, allEntries } = Astro.props;
const { Content } = await render(seriesEntry);

// Get all articles belonging to this series (entries in subfolders matching the series slug)
const seriesArticles = allEntries
  .filter((entry) => entry.id.startsWith(`${seriesEntry.id}/`))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group articles by track
const articlesByTrack: Record<string, typeof seriesArticles> = {};
for (const article of seriesArticles) {
  const track = article.data.track || article.data.techStack?.[0] || 'articles';
  if (!articlesByTrack[track]) articlesByTrack[track] = [];
  articlesByTrack[track].push(article);
}

const data = seriesEntry.data;
const statusColor = statusColors[data.status] || statusColors.active;
const statusLabel = statusLabels[data.status] || data.status;

// OG image URL
const ogImageUrl = `/og/projects/${seriesEntry.id}.png`;

// Schema.org listing items
const listingItems = seriesArticles.map((article) => ({
  title: article.data.title,
  url: `${SITE_URL}/series/${seriesEntry.id}/${article.id.split('/').pop()}/`,
}));
---

<Layout
  title={data.title}
  description={data.description}
  pageType="project"
  featureImageUrl={data.heroImage || ogImageUrl}
  techStack={data.techStack}
  projectUrl={data.url}
  repoUrl={data.repo}
  listingItems={listingItems}
>
  <div class="bg-gradient-to-br from-purple-50 via-white to-cyan-50 dark:from-gray-900 dark:via-gray-950 dark:to-cyan-950/50">
    <!-- Breadcrumb -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-8">
      <nav aria-label="Breadcrumb" class="flex items-center gap-1.5 text-sm">
        <a href="/" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors">Home</a>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="/series/" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors">Series</a>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-gray-600 dark:text-gray-400">{data.title}</span>
      </nav>
    </div>

    <!-- ===== HERO ===== -->
    <section class="py-12 sm:py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <!-- Status badge -->
        <div class="mb-6">
          <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ring-1 ring-inset ${statusColor}`}>
            {statusLabel}
          </span>
          {data.featured && (
            <span class="ml-2 inline-flex items-center rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-100 dark:bg-amber-950 dark:text-amber-300 dark:ring-amber-800">
              Featured
            </span>
          )}
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight">
          {data.title}
        </h1>

        {data.tagline && (
          <p class="mt-4 text-xl sm:text-2xl text-purple-600 dark:text-purple-400 font-medium">
            {data.tagline}
          </p>
        )}

        <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
          {data.description}
        </p>

        <!-- Metadata row -->
        <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-gray-500 dark:text-gray-400">
          {data.articleCount && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
              {data.articleCount} articles
            </span>
          )}
          {data.wordCount && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              {data.wordCount}
            </span>
          )}
          {data.tracks && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
              {data.tracks.length} tracks
            </span>
          )}
        </div>

        <!-- Primary CTA -->
        {data.status === 'active' && seriesArticles.length > 0 && (
          <div class="mt-10">
            <a
              href={`/series/${seriesEntry.id}/${seriesArticles[0].id.split('/').pop()}/`}
              class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-8 py-4 text-lg font-semibold text-white shadow-lg transition-all hover:bg-indigo-700 hover:shadow-xl hover:-translate-y-0.5 dark:bg-indigo-500 dark:hover:bg-indigo-600"
            >
              Start from the beginning
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- ===== THREE TRACKS ===== -->
    {data.tracks && data.tracks.length > 0 && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-10">Three Parallel Tracks</h2>
          <p class="text-center text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-12">
            Every week, one article from each track publishes in rotation. Follow one track or read them all — each stands on its own.
          </p>
          <div class="grid gap-8 md:grid-cols-3">
            {data.tracks.map((track: { name: string; code: string; description: string }, i: number) => {
              const icons = [
                '<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>',
                '<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>',
                '<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>',
              ];
              const colors = [
                'from-indigo-500 to-purple-500 dark:from-indigo-400 dark:to-purple-400',
                'from-emerald-500 to-teal-500 dark:from-emerald-400 dark:to-teal-400',
                'from-amber-500 to-orange-500 dark:from-amber-400 dark:to-orange-400',
              ];
              return (
                <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-8 shadow-sm">
                  <div class={`inline-flex items-center justify-center rounded-xl bg-gradient-to-br ${colors[i]} p-3 text-white mb-5`}>
                    <Fragment set:html={icons[i]} />
                  </div>
                  <div class="text-xs font-mono text-gray-400 dark:text-gray-500 mb-2">{track.code}</div>
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">{track.name}</h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">{track.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- ===== PUBLISHED ARTICLES ===== -->
    {seriesArticles.length > 0 && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-10">Published Articles</h2>

          {Object.entries(articlesByTrack).map(([track, articles]) => (
            <div class="mb-10 last:mb-0">
              <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4 flex items-center gap-2">
                <span class="inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-700 dark:bg-purple-950 dark:text-purple-300">
                  {track === 'articles' ? 'A-Series' : track === 'profiles' ? 'P-Series' : track === 'events' ? 'E-Series' : track}
                </span>
              </h3>
              <div class="grid gap-3">
                {articles.map((article) => {
                  const articleSlug = article.id.split('/').pop();
                  return (
                    <a
                      href={`/series/${seriesEntry.id}/${articleSlug}/`}
                      class="group flex items-start gap-4 rounded-xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
                    >
                      <div class="shrink-0 mt-0.5">
                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600 dark:bg-emerald-950 dark:text-emerald-400">
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                        </span>
                      </div>
                      <div class="min-w-0 flex-grow">
                        <h4 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors leading-snug">
                          {article.data.title}
                        </h4>
                        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
                          {article.data.description}
                        </p>
                      </div>
                      <svg class="shrink-0 h-5 w-5 text-gray-300 dark:text-gray-600 group-hover:text-purple-500 transition-colors mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ===== THE FIVE ACTS ===== -->
    {data.acts && data.acts.length > 0 && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-4">The Story Arc</h2>
          <p class="text-center text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-12">
            Five acts spanning thousands of years — from the first dream of artificial life to the present revolution.
          </p>
          <div class="relative">
            <!-- Timeline line -->
            <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-300 via-purple-300 to-cyan-300 dark:from-indigo-700 dark:via-purple-700 dark:to-cyan-700 hidden md:block" />

            <div class="space-y-6">
              {data.acts.map((act: { name: string; roman: string; description: string }, i: number) => (
                <div class="relative md:pl-16">
                  <!-- Timeline dot -->
                  <div class="absolute left-4 top-4 hidden md:block">
                    <div class="h-5 w-5 rounded-full border-4 border-white dark:border-gray-950 bg-gradient-to-br from-indigo-500 to-purple-500 dark:from-indigo-400 dark:to-purple-400 shadow-sm" />
                  </div>

                  <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                      <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 dark:from-indigo-400 dark:to-purple-400 text-white font-bold text-sm">
                        {act.roman}
                      </span>
                      <h3 class="text-lg font-bold text-gray-900 dark:text-white">Act {act.roman}: {act.name}</h3>
                    </div>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">{act.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ===== BY THE NUMBERS ===== -->
    {data.articleCount && (
      <section class="pb-16">
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-10">By the Numbers</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 text-center shadow-sm">
              <div class="text-3xl font-extrabold text-indigo-600 dark:text-indigo-400">{data.articleCount}</div>
              <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">Articles</div>
            </div>
            <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 text-center shadow-sm">
              <div class="text-3xl font-extrabold text-purple-600 dark:text-purple-400">{data.wordCount || '—'}</div>
              <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">Total words</div>
            </div>
            <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 text-center shadow-sm">
              <div class="text-3xl font-extrabold text-emerald-600 dark:text-emerald-400">{data.tracks?.length || '—'}</div>
              <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">Tracks</div>
            </div>
            <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 text-center shadow-sm">
              <div class="text-3xl font-extrabold text-amber-600 dark:text-amber-400">{data.acts?.length || '—'}</div>
              <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">Acts</div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ===== BOTTOM CTA ===== -->
    {data.status === 'active' && seriesArticles.length > 0 && (
      <section class="pb-20">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
          <div class="rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-800 dark:to-purple-900 p-10 sm:p-14">
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">Ready to dive in?</h2>
            <p class="text-indigo-100 mb-8 max-w-lg mx-auto">
              Start from the very first article and follow the story from ancient dreams to modern intelligence.
            </p>
            <a
              href={`/series/${seriesEntry.id}/${seriesArticles[0].id.split('/').pop()}/`}
              class="inline-flex items-center gap-2 rounded-xl bg-white px-8 py-4 text-lg font-semibold text-indigo-700 shadow-lg transition-all hover:bg-indigo-50 hover:shadow-xl hover:-translate-y-0.5"
            >
              {seriesArticles[0].data.title}
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>
