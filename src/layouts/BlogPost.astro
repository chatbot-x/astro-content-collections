---
/**
 * BlogPost layout — two-column article layout with sticky sidebar.
 *
 * Desktop (lg+):  main prose column + sticky sidebar (TOC, share, meta)
 * Mobile:         single column with inline TOC & share buttons
 *
 * All styling via Tailwind — no scoped CSS.
 */
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  heroImage?: string;
  readingTime?: string;
  wordCount?: number;
  url?: string;
  headings?: Heading[];
}

import { SITE_URL } from '../utils/site';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'Ishaan',
  tags = [],
  heroImage,
  readingTime,
  wordCount,
  url,
  headings = [],
} = Astro.props;

const shareUrl = url || Astro.url.href;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasToc = tocHeadings.length >= 2;
---

<ReadingProgress />

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12" data-pagefind-body>
  <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-12">
    <!-- ═══════════════════════════════════════ -->
    <!-- Main column                              -->
    <!-- ═══════════════════════════════════════ -->
    <div class="min-w-0 max-w-3xl">
      <!-- Hero image -->
      {heroImage && (
        <div class="mb-8 rounded-2xl overflow-hidden">
          <img src={heroImage} alt={title} class="w-full h-64 object-cover" />
        </div>
      )}

      <!-- Article header -->
      <header class="mb-10">
        <h1
          class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight"
          data-pagefind-meta="title"
        >
          {title}
        </h1>
        {description && (
          <p class="mt-4 text-xl text-gray-600 dark:text-gray-400 leading-relaxed">{description}</p>
        )}

        <!-- Meta row: author · date · reading time · word count · updated -->
        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-xs font-bold">
              {author.charAt(0).toUpperCase()}
            </div>
            <span class="font-medium text-gray-700 dark:text-gray-300" data-pagefind-filter="author">{author}</span>
          </div>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {readingTime && (
            <>
              <span class="text-gray-300 dark:text-gray-600">|</span>
              <span>{readingTime}</span>
            </>
          )}
          {wordCount && (
            <>
              <span class="text-gray-300 dark:text-gray-600">|</span>
              <span>{wordCount.toLocaleString()} words</span>
            </>
          )}
          {updatedDate && (
            <span class="text-gray-400 dark:text-gray-500">
              (Updated: <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time>)
            </span>
          )}
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2" data-pagefind-filter="tags">
            {tags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-100 dark:bg-indigo-950 dark:text-indigo-300 dark:ring-indigo-800">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Mobile-only: inline TOC + share buttons -->
      <div class="lg:hidden mb-8 space-y-4">
        {hasToc && <TableOfContents headings={headings} />}
        <!-- Share buttons (mobile inline) -->
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mr-1">Share</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-indigo-600 dark:hover:text-indigo-400"
            aria-label="Share on X (Twitter)"
          >
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a
            href={`https://www.reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-orange-600 dark:hover:text-orange-400"
            aria-label="Share on Reddit"
          >
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
