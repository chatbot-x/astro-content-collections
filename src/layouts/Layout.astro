---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
import Navbar from '../components/Navbar.astro';
import SearchModal from '../components/SearchModal.astro';
import Footer from '../components/Footer.astro';
import { buildSchemaGraph } from '../utils/schema';
import type { SchemaGraphOpts } from '../utils/schema';
import { SITE_URL } from '../utils/site';
import '../styles/global.css';

/**
 * Resolve a potentially relative URL to an absolute URL.
 * Schema.org JSON-LD and Open Graph og:image require absolute URLs.
 */
function resolveAbsoluteUrl(url: string | undefined): string | undefined {
  if (!url) return undefined;
  try {
    // If already absolute, return as-is
    new URL(url);
    return url;
  } catch {
    // Relative URL — prepend SITE_URL
    return `${SITE_URL}${url.startsWith('/') ? '' : '/'}${url}`;
  }
}

interface Props {
  title: string;
  description?: string;
  pageType?: SchemaGraphOpts['pageType'];
  publishDate?: Date;
  updatedDate?: Date;
  featureImageUrl?: string;
  category?: string;
  wordCount?: number;
  articleType?: SchemaGraphOpts['articleType'];
  techStack?: string[];
  projectUrl?: string;
  repoUrl?: string;
  listingItems?: SchemaGraphOpts['listingItems'];
}

const {
  title,
  description = 'isHistory is a curated digital archive of the stories behind technology — how ideas sparked, why systems failed or succeeded, and the people who shaped the digital age without ever showing a single line of code.',
  pageType = 'page',
  publishDate,
  updatedDate,
  featureImageUrl,
  category,
  wordCount,
  articleType,
  techStack,
  projectUrl,
  repoUrl,
  listingItems,
} = Astro.props;

// FIX: Resolve featureImageUrl to absolute URL for Schema.org JSON-LD and Open Graph.
// Relative URLs (e.g., '/og/blog/slug.png') are invalid in og:image and Schema.org image objects.
const absoluteFeatureImageUrl = resolveAbsoluteUrl(featureImageUrl);

// FIX: Smart title formatting to avoid redundancy and excessive length.
// - Homepage: "isHistory" (no redundant suffix)
// - Pages with short titles: "Page Title | isHistory"
// - Blog posts with long titles (>60 chars with suffix): omit suffix
//   to prevent truncation in SERPs. Google displays ~60 chars.
const siteName = 'isHistory';
const SEPARATOR = ' | ';
const MAX_TITLE_LENGTH = 60;
let formattedTitle: string;
if (title === siteName) {
  // Homepage: avoid "isHistory | isHistory"
  formattedTitle = title;
} else {
  const titleWithSuffix = `${title}${SEPARATOR}${siteName}`;
  formattedTitle = titleWithSuffix.length > MAX_TITLE_LENGTH
    ? title  // Long titles: omit suffix to stay within SERP limits
    : titleWithSuffix;
}

// FIX: Resolve featureImageUrl to absolute URL for Twitter Card image.
// Twitter Cards require absolute URLs for twitter:image.
const twitterImageUrl = absoluteFeatureImageUrl || `${SITE_URL}/og-default.jpg`;

const graph = buildSchemaGraph({
  pageType,
  url: Astro.url.href,
  title,
  description,
  publishDate,
  updatedDate,
  featureImageUrl: absoluteFeatureImageUrl,
  category,
  wordCount,
  articleType,
  techStack,
  projectUrl,
  repoUrl,
  listingItems,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <ThemeProvider defaultTheme="system" />
    <Seo
      title={formattedTitle}
      description={description}
      canonical={Astro.url.href}
      ogType={pageType === 'blogPost' ? 'article' : 'website'}
      ogImage={absoluteFeatureImageUrl || `${SITE_URL}/og-default.jpg`}
      ogImageAlt={title}
      ogImageWidth={1200}
      ogImageHeight={675}
      siteName={siteName}
      article={pageType === 'blogPost' && publishDate ? { publishedTime: publishDate, tags: category ? [category] : undefined } : undefined}
      graph={graph}
      extraLinks={[
        { rel: 'icon', type: 'image/png', sizes: '32x32', href: '/favicon-32x32.png' },
        { rel: 'icon', type: 'image/x-icon', href: '/favicon.ico' },
        { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
        { rel: 'apple-touch-icon', sizes: '180x180', href: '/apple-touch-icon.png' },
        // FIX: RSS auto-discovery — enables RSS readers and browsers to find the feed
        // at /rss.xml without the user needing to know the URL.
        { rel: 'alternate', type: 'application/rss+xml', title: 'isHistory', href: '/rss.xml' },
        // NOTE: Preconnect hints for Google Fonts were removed (AUD-013).
        // This project uses system font stacks, not Google Fonts.
        // Re-add if Google Fonts are introduced in the future.
      ]}
    />
    {/* FIX: Twitter Card meta tags — essential for rich tweet previews.
        These tags are required by Twitter/X, LinkedIn, and other social
        platforms that use Twitter Card markup for link previews.
        While Open Graph covers Facebook, Twitter Cards are a separate
        standard and are widely supported across platforms. */}
    <meta name="twitter:card" content={pageType === 'blogPost' ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={formattedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased transition-colors duration-200 dark:bg-gray-950 dark:text-gray-100">
    <!-- Skip navigation link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-indigo-600 focus:px-4 focus:py-2 focus:text-white focus:shadow-lg">
      Skip to main content
    </a>
    <SearchModal />
    <!-- FIX: Wrapped Navbar in <header> element for proper semantic HTML.
         The <header> element provides the banner landmark, which helps
         screen reader users navigate page sections via landmark navigation.
         Previously, the nav was present but lacked the enclosing banner landmark. -->
    <header>
      <Navbar />
    </header>
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
