# Cloudflare Pages security headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Apply security headers to all pages
/*
  # NOTE: Content Security Policy is NOT set here. Astro's security.csp
  # configuration has a known bug where <script is:inline> bodies are not
  # added to the script-src hash allowlist, causing browsers to block:
  #   - Theme toggle (depends on window.__ASTRO_THEMES__)
  #   - Dark mode initialization (FOUC prevention)
  #   - View Transitions (inline event handlers)
  # Upstream issue: https://github.com/withastro/astro/issues/16664
  # Once resolved, add Content-Security-Policy header here for defense-in-depth.
  # The meta-tag CSP (if enabled) alone provides the same protection since CSP
  # is enforced at the document level regardless of delivery mechanism.
  # Prevent clickjacking — the site should not be embedded in iframes
  X-Frame-Options: DENY
  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff
  # Referrer policy — only send origin to external sites
  Referrer-Policy: strict-origin-when-cross-origin
  # Permissions policy — disable features not used by this site
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # XSS Protection (legacy, but still useful for older browsers)
  X-XSS-Protection: 1; mode=block
  # Strict Transport Security — enforce HTTPS for 1 year, include subdomains, allow preloading
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache static assets aggressively — fonts, images, CSS, JS
# Cloudflare serves these with its own CDN cache; explicit Cache-Control
# ensures browsers also cache them, reducing repeat requests.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache OG images for 1 year (they only change on rebuild)
/og/*
  Cache-Control: public, max-age=31536000, immutable

# Cache favicon and static assets for 7 days
/*.png
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800

# IndexNow key file — no caching (must always verify)
/101ca11c95314d7094344c49eea380f9.txt
  Cache-Control: no-cache
